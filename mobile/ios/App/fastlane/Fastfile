default_platform(:ios)

$package_json_path = '../../../../package.json'
$workspace_path = 'App.xcworkspace'
$project_path = '../App.xcodeproj/project.pbxproj'

def env_value(name, fallback = nil)
  value = ENV[name]
  value.nil? || value.empty? ? fallback : value
end

$variant = env_value('APP_VARIANT', 'mytonwallet').downcase
$variant_config = {
  'mytonwallet' => {
    app_identifier: 'org.mytonwallet.app',
    app_identifier_widget: 'org.mytonwallet.app.AirWidget',
    profile_name: 'MyTonWallet Production profile',
    profile_name_widget: 'MyTonWallet Production profile - Widget',
    scheme: 'MyTonWallet',
    scheme_widget: 'AirWidgetExtension',
    plist_path: '../../App/App/Info.plist',
    testflight_group: 'MTW external group',
  },
  'gram' => {
    app_identifier: 'io.gramwallet.app',
    app_identifier_widget: 'io.gramwallet.app.widget',
    profile_name: 'Gram Wallet Production profile',
    profile_name_widget: 'Gram Wallet Production profile - Widget',
    scheme: 'GramWallet',
    scheme_widget: 'GramWalletWidgetExtension',
    plist_path: '../../App/App/GramWallet-Info.plist',
    testflight_group: 'Gram Wallet external group',
  },
}

raise "Unknown APP_VARIANT: #{$variant}" unless $variant_config.key?($variant)

$config = $variant_config[$variant]
$plist_path = env_value('IOS_PLIST_PATH', $config[:plist_path])

$team_id = env_value('IOS_TEAM_ID', CredentialsManager::AppfileConfig.try_fetch_value(:team_id))
$app_identifier = env_value('IOS_APP_IDENTIFIER', $config[:app_identifier])
$profile_name = env_value('IOS_PROFILE_NAME', $config[:profile_name])
$scheme = env_value('IOS_SCHEME', $config[:scheme])
$app_identifier_widget = env_value('IOS_APP_IDENTIFIER_WIDGET', $config[:app_identifier_widget])
$profile_name_widget = env_value('IOS_PROFILE_NAME_WIDGET', $config[:profile_name_widget])
$scheme_widget = env_value('IOS_WIDGET_SCHEME', $config[:scheme_widget])
$testflight_group = env_value('IOS_TESTFLIGHT_GROUP', $config[:testflight_group])
$metadata_path = env_value('IOS_METADATA_PATH')
$asc_key_id = env_value('APP_STORE_CONNECT_KEY_ID', 'TL49GJ73DP')
$asc_issuer_id = env_value('APP_STORE_CONNECT_ISSUER_ID', '519080b4-bc5f-4d06-a889-a69254108348')
$asc_key_path = env_value('APP_STORE_CONNECT_KEY_PATH', './AuthKey.p8')

puts "$variant: #{$variant}"
puts "$app_identifier: #{$app_identifier}"
puts "$profile_name: #{$profile_name}"
puts "$scheme: #{$scheme}"
puts "$app_identifier_widget: #{$app_identifier_widget}"
puts "$profile_name_widget: #{$profile_name_widget}"
puts "$scheme_widget: #{$scheme_widget}"
puts "$testflight_group: #{$testflight_group}"

$project_data = nil
$plist_data = nil

def read_files
  $project_data = File.read($project_path)
  $plist_data = File.read($plist_path)
end

def restore_files
  File.write($project_path, $project_data)
  File.write($plist_path, $plist_data)
end

def update_version_and_build_number
  version = JSON.parse(File.read($package_json_path))["version"]
  production_build_number = 0
  begin
    production_build_number = app_store_build_number(app_identifier: $app_identifier, version: version, initial_build_number: 0, live: true).to_i
  rescue
  end
  beta_build_number = latest_testflight_build_number(app_identifier: $app_identifier, version: version, initial_build_number: 0)
  build_number = [production_build_number, beta_build_number].max() + 1

  increment_version_number(version_number: version)
  increment_build_number(skip_info_plist: true, build_number: build_number)

  return version, build_number
end

platform :ios do
  desc "Push a new beta build to TestFlight"

  before_all do |lane|
    read_files

    app_store_connect_api_key(
      key_id: $asc_key_id,
      issuer_id: $asc_issuer_id,
      key_filepath: $asc_key_path,
      duration: 1200,
      in_house: false
    )

    update_code_signing_settings(
      path: "App.xcodeproj",
      use_automatic_signing: false,
      profile_name: $profile_name,
      sdk: "iphoneos*",
      team_id: $team_id,
      targets: [$scheme],
      code_sign_identity: "iPhone Distribution"
    )

    update_code_signing_settings(
      path: "App.xcodeproj",
      use_automatic_signing: false,
      profile_name: $profile_name_widget,
      sdk: "iphoneos*",
      team_id: $team_id,
      targets: [$scheme_widget],
      code_sign_identity: "iPhone Distribution"
    )
  end

  lane :beta do
    update_version_and_build_number

    build_app(
      workspace: $workspace_path,
      scheme: $scheme,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          $app_identifier => $profile_name,
          $app_identifier_widget => $profile_name_widget,
        }
      },
      xcargs: "-skipMacroValidation",
    )

    changelog_from_git_commits(merge_commit_filtering: "exclude_merges", commits_count: 3)
    upload_to_testflight(
      app_identifier: $app_identifier,
      distribute_external: true,
      groups: $testflight_group,
      beta_app_description: "Bug fixes and performance improvements"
    )
  end

  lane :release do
    version, build_number = update_version_and_build_number

    changelog_path = "../../../../changelogs/" + version + ".txt"
    if !File.exist?(changelog_path)
      raise "There is no changelog for version " + version
    end

    changelog = File.read(changelog_path)

    build_app(
      workspace: $workspace_path,
      scheme: $scheme,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          $app_identifier => $profile_name,
          $app_identifier_widget => $profile_name_widget,
        }
      },
      xcargs: "-skipMacroValidation",
    )

    upload_options = {
      app_identifier: $app_identifier,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: true,
      submission_information: {
        add_id_info_uses_idfa: false
      },
      force: true,
      release_notes: {
        "default" => changelog,
        "en-US" => changelog,
      }
    }
    upload_options[:metadata_path] = $metadata_path if $metadata_path
    upload_to_app_store(upload_options)
  end

  after_all do |lane|
    restore_files
  end

  error do |lane, exception|
    restore_files
  end

end
