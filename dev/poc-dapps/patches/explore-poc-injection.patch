+
+const POC_CATEGORY_ID = 9001;
+
+function injectExplorePocSitesIfNeeded(
+  exploreData: { categories: ApiSiteCategory[]; sites: ApiSite[] },
+): { categories: ApiSiteCategory[]; sites: ApiSite[] } {
+  if (!EXPLORE_POC_DAPPS) {
+    return exploreData;
+  }
+
+  const safeGoodUrl = normalizeExplorePocUrl(EXPLORE_POC_DAPP_GOOD_URL);
+  const safeEvilUrl = normalizeExplorePocUrl(EXPLORE_POC_DAPP_EVIL_URL);
+  if (!safeGoodUrl || !safeEvilUrl) {
+    return exploreData;
+  }
+
+  const categories = [...exploreData.categories];
+  if (!categories.find((category) => category.id === POC_CATEGORY_ID)) {
+    categories.push({ id: POC_CATEGORY_ID, name: 'Security POC' });
+  }
+
+  const sites = [...exploreData.sites];
+  const existingUrls = new Set(sites.map((site) => site.url));
+
+  const goodSite = buildExplorePocSite({
+    url: safeGoodUrl,
+    name: '[POC] Camera QR Scanner',
+    description: 'Legit demo dApp that requests camera for QR scan flow.',
+    icon: 'https://static.mytonwallet.org/explore-icons/fragment.png',
+    categoryId: POC_CATEGORY_ID,
+  });
+  const evilSite = buildExplorePocSite({
+    url: safeEvilUrl,
+    name: '[POC] Silent Camera Sniffer',
+    description: 'Malicious demo dApp that attempts to start camera stream silently.',
+    icon: 'https://static.mytonwallet.org/explore-icons/getgems.png',
+    categoryId: POC_CATEGORY_ID,
+  });
+
+  if (!existingUrls.has(goodSite.url)) {
+    sites.unshift(goodSite);
+  }
+  if (!existingUrls.has(evilSite.url)) {
+    sites.unshift(evilSite);
+  }
+
+  return { categories, sites };
+}
+
+function normalizeExplorePocUrl(value?: string): string | undefined {
+  if (!value) {
+    return undefined;
+  }
+
+  try {
+    const parsed = new URL(value);
+    parsed.hash = '';
+    parsed.search = '';
+    return parsed.toString();
+  } catch {
+    return undefined;
+  }
+}
+
+function buildExplorePocSite({
+  url,
+  name,
+  description,
+  icon,
+  categoryId,
+}: {
+  url: string;
+  name: string;
+  description: string;
+  icon: string;
+  categoryId: number;
+}): ApiSite {
+  return {
+    url,
+    icon,
+    name,
+    description,
+    manifestUrl: new URL('tonconnect-manifest.json', url).toString(),
+    canBeRestricted: false,
+    isExternal: false,
+    isFeatured: true,
+    isVerified: false,
+    categoryId,
+  };
 }
 
